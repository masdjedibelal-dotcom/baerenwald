/**
 * Mock topbar() — Strukturreferenz (ohne Demo-Controls).
 * Quelle: Baerenwald Portale (5).html
 *
 * Live: PortalTopbar — Mark · Titel · Sub · Divider · Spacer · notifications (B4)
 * Entfernt: Rollen-Pills, Zustand-Select, HV/Privat-Toggle, Desktop/Mobil-Toggle
 */
{
  "padding": "11px 16px",
  "background": "#fff",
  "borderBottom": "1px solid C.line",
  "sticky": true,
  "zIndex": 50,
  "gap": 12,
  "brand": {
    "mark": { "size": 26, "radius": 6, "bg": "C.primary", "color": "#fff", "fontSize": 13 },
    "title": { "font": "C.head", "weight": 700, "size": 15, "color": "C.ink" },
    "sub": {
      "size": 11,
      "color": "C.faint",
      "weight": 600,
      "letterSpacing": 0.4,
      "textTransform": "uppercase",
      "default": "Portale"
    }
  },
  "divider": { "width": 1, "height": 22, "bg": "C.line" },
  "right": "notifications (bell / B4)"
}
