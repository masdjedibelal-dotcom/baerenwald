{
  "name": "baerenwald-crm-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "dev:skip-auth": "CRM_DEV_SKIP_AUTH=true WATCHPACK_POLLING=true next dev -p 3001",
    "dev:clean": "rm -rf .next && WATCHPACK_POLLING=true next dev",
    "build": "node scripts/remove-deploy-blockers.mjs && node scripts/check-critical-files.mjs && node scripts/check-import-paths.mjs && node scripts/check-client-imports.mjs && next build",
    "build:check-imports": "node scripts/check-import-paths.mjs",
    "start": "next start",
    "lint": "next lint",
    "setup:chrome": "npx @puppeteer/browsers install chrome-headless-shell@stable --path chrome-headless-shell && node scripts/write-pdf-chrome-env.mjs",
    "test:pdf": "node scripts/verify-pdf.mjs",
    "test:angebot-positionen": "node scripts/test-angebot-positionen-flow.mjs",
    "db:einstellungen": "node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/einstellungen-setup.sql",
    "db:rechnungen-compliance": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260521120000_rechnungen_compliance.sql",
    "db:rechnung-nummer": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260601130000_rechnung_nummer_re2026.sql",
    "db:rechnung-nummer-2069": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260610180000_rechnung_nummer_start_2069.sql",
    "db:rechnung-texte": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260601130001_rechnungen_pdf_texte.sql",
    "db:zahlungsplan": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260704120000_zahlungsplan_abschlagsrechnungen.sql",
    "db:rechnungen-zahlungsbedingungen": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260712120000_rechnungen_zahlungsbedingungen.sql",
    "db:rechnungen-hinweis-35a": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260713120000_rechnungen_hinweis_35a.sql",
    "db:rechnungen-all": "npm run db:rechnungen-compliance && npm run db:rechnung-nummer && npm run db:rechnung-nummer-2069 && npm run db:rechnung-texte && npm run db:zahlungsplan && npm run db:rechnungen-zahlungsbedingungen && npm run db:rechnungen-hinweis-35a",
    "db:abschlagsrechnungen": "npm run db:zahlungsplan && npm run db:rechnungen-zahlungsbedingungen",
    "db:portal-fix": "node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/fix-portal-token-not-exists.sql",
    "db:rls-recursion-fix": "node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/fix-angebote-rls-recursion.sql",
    "db:partner-portal": "node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/partner-portal/01_portal_auth_handwerker.sql && node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/partner-portal/02_portal_handwerker_angebot_einreichung.sql && node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/partner-portal/03_portal_handwerker_bautagebuch.sql && node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/partner-portal/04_portal_handwerker_storage_policies.sql",
    "db:storage-buckets": "node --env-file=.env.local scripts/apply-sql-migration.mjs scripts/sql/storage-buckets-crm-setup.sql",
    "db:hw-rechnung-einreichung": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260603120500_portal_handwerker_rechnung_einreichung.sql",
    "db:angebot-handwerker-gaps": "node --env-file=.env.local scripts/apply-gap-repair.mjs",
    "docs:screenshots": "node --env-file=.env.local scripts/docs-screenshots/capture.mjs",
    "docs:pdf": "node --env-file=.env.local scripts/docs-screenshots/build-pdf.mjs",
    "docs:ui": "node --env-file=.env.local scripts/docs-screenshots/capture.mjs && node --env-file=.env.local scripts/docs-screenshots/build-pdf.mjs",
    "db:bautagebuch-gewerk": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260601140000_bautagebuch_gewerk_id.sql",
    "db:ki-analysen": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260612120000_ki_cluster_analysen.sql",
    "db:ki-historik": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260613120000_ki_historische_daten.sql",
    "db:handwerker-vertraege": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260614120000_handwerker_vertraege.sql",
    "db:compliance-scope": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260615120000_compliance_dokument_scope.sql",
    "db:compliance-auftrag": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260616120000_partner_dokumente_auftrag.sql",
    "db:compliance": "npm run db:compliance-scope && npm run db:compliance-auftrag",
    "db:compliance-vertraege": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260617120000_compliance_vertraege_portal.sql",
    "db:portal-alignment": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260618120000_portal_partner_alignment.sql",
    "db:ki-viz": "node --env-file=.env.local scripts/apply-sql-migration.mjs supabase/migrations/20260620120000_ki_visualisierungen.sql",
    "import:historik": "node --env-file=.env.local scripts/import-historik-xlsx.mjs",
    "import:historik:ki": "node --env-file=.env.local scripts/import-historik-xlsx.mjs && npm run ki:analyse:preise && npm run ki:analyse:produkte && npm run ki:analyse:claude",
    "ki:analyse:funnel": "node --env-file=.env.local scripts/ki-analyse/funnel.mjs",
    "ki:analyse:nachfrage": "node --env-file=.env.local scripts/ki-analyse/nachfrage.mjs",
    "ki:analyse:kommunikation": "node --env-file=.env.local scripts/ki-analyse/kommunikation.mjs",
    "ki:analyse:angebot-abgleich": "node --env-file=.env.local scripts/ki-analyse/angebot-abgleich.mjs",
    "ki:analyse:preise": "node --env-file=.env.local scripts/ki-analyse/preise-margen.mjs",
    "ki:analyse:handwerker": "node --env-file=.env.local scripts/ki-analyse/handwerker.mjs",
    "ki:analyse:gewerke": "node --env-file=.env.local scripts/ki-analyse/gewerke.mjs",
    "ki:analyse:ausfuehrung": "node --env-file=.env.local scripts/ki-analyse/ausfuehrung.mjs",
    "ki:analyse:dauer": "node --env-file=.env.local scripts/ki-analyse/dauer.mjs",
    "ki:analyse:bewertungen": "node --env-file=.env.local scripts/ki-analyse/bewertungen.mjs",
    "ki:analyse:produkte": "node --env-file=.env.local scripts/ki-analyse/produkte.mjs",
    "ki:analyse:all": "node --env-file=.env.local scripts/ki-analyse/funnel.mjs && node --env-file=.env.local scripts/ki-analyse/nachfrage.mjs && node --env-file=.env.local scripts/ki-analyse/kommunikation.mjs && node --env-file=.env.local scripts/ki-analyse/angebot-abgleich.mjs && node --env-file=.env.local scripts/ki-analyse/preise-margen.mjs && node --env-file=.env.local scripts/ki-analyse/produkte.mjs && node --env-file=.env.local scripts/ki-analyse/gewerke.mjs && node --env-file=.env.local scripts/ki-analyse/ausfuehrung.mjs && node --env-file=.env.local scripts/ki-analyse/handwerker.mjs && node --env-file=.env.local scripts/ki-analyse/dauer.mjs && node --env-file=.env.local scripts/ki-analyse/bewertungen.mjs",
    "ki:analyse:claude": "node --env-file=.env.local scripts/ki-analyse/claude-auswertung.mjs",
    "ki:analyse:full": "npm run ki:analyse:all && npm run ki:analyse:claude"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@netlify/plugin-nextjs": "^5.12.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sparticuz/chromium": "^131.0.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "archiver": "^8.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.35",
    "papaparse": "^5.5.3",
    "puppeteer-core": "^24.43.1",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.12.0",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/archiver": "^8.0.0",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "postgres": "^3.4.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
